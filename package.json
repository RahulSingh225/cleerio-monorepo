{
  "name": "cleerio-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "concurrently \"npm:build:api\" \"npm:build:worker\" \"npm:build:dashboard\"",
    "build:api": "npx pnpm --prefix apps/api build",
    "build:worker": "npx pnpm --prefix apps/worker build",
    "build:dashboard": "npx pnpm --prefix apps/dashboard build",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:dashboard\"",
    "dev:api": "npx pnpm --prefix apps/api dev",
    "dev:worker": "npx pnpm --prefix apps/worker dev",
    "dev:dashboard": "npx pnpm --prefix apps/dashboard dev",
    "typecheck": "npx -p typescript tsc --noEmit",
    "typecheck:api": "npx pnpm --prefix apps/api exec tsc --noEmit",
    "lint": "npx pnpm -r lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/testing": "^11.1.17",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
