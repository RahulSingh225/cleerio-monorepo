# ==============================================================================
# Cleerio Monorepo - Production Environment Template
# ==============================================================================

# Node Environment
NODE_ENV=production

# ------------------------------------------------------------------------------
# Database (PostgreSQL) - Hosted on EC2
# ------------------------------------------------------------------------------
# Format: postgresql://user:password@host:port/dbname?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/collections_db?schema=public"

# ------------------------------------------------------------------------------
# Redis - Separately Deployed
# ------------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# ------------------------------------------------------------------------------
# Kafka - Hosted on separate EC2
# ------------------------------------------------------------------------------
# Comma-separated list of brokers
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="cleerio-api"
KAFKA_GROUP_ID="cleerio-worker-pool"

# ------------------------------------------------------------------------------
# AWS / S3 - For file uploads and audio recordings
# ------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="cleerio-prod-assets"
# Leave empty for real S3, or provide URL for MinIO/LocalStack
S3_ENDPOINT=""

# ------------------------------------------------------------------------------
# Security & Auth
# ------------------------------------------------------------------------------
JWT_SECRET="generate-a-long-random-string-for-production"
JWT_EXPIRATION="24h"

# CORS: Comma-separated list of allowed origins
ALLOWED_ORIGINS="https://dashboard.cleerio.com,https://api.cleerio.com"

# ------------------------------------------------------------------------------
# Application Ports (Used by Docker and NestJS)
# ------------------------------------------------------------------------------
API_PORT=3000
WORKER_PORT=3002
DASHBOARD_PORT=3001

# ------------------------------------------------------------------------------
# Dashboard Setup
# ------------------------------------------------------------------------------
# The URL where the API is accessible from the browser
NEXT_PUBLIC_API_URL="https://api.cleerio.com/v1"
